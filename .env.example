# Copy this file to `.env.local` and fill in the values.
# `.env.local` is gitignored and must never be committed.

# ── Supabase ─────────────────────────────────────────────────────────────────
# For LOCAL development: run `npx supabase start` once and it prints these three
# values to the terminal (API URL, anon key, service_role key). Paste them here.
#
# For PRODUCTION (Vercel): create a project at https://supabase.com/dashboard,
# then Settings → API gives you the same three values. Set the SAME variable
# names in Vercel → Project → Settings → Environment Variables.

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ── Auth (email-free login) ──────────────────────────────────────────────────
# Usernames map to synthetic internal emails so Supabase Auth works without
# requiring real mailboxes. Login is by username; this domain is appended
# under the hood. You generally do not need to change this.

SYNTHETIC_EMAIL_DOMAIN=magneticjoezion.local